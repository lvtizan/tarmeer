# Copy to .env and adjust. For local dev use PORT=3001, NODE_ENV=development.
# Database (local or Aliyun RDS)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=tarmeer

# Aliyun RDS example (Dubai):
# DB_HOST=rm-eb3t6y5093m91i2wzqo.mysql.dubai.rds.aliyuncs.com
# DB_PORT=3306
# DB_USER=tarmeerCRM
# DB_PASSWORD=your_rds_password
# DB_NAME=tarmeer

# JWT 配置
JWT_SECRET=your_jwt_secret_here_change_in_production

# SMTP（阿里云邮件推送，与公司 Spring 配置一致）
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@mail.kptom.com
SMTP_PASS=your_aliyun_smtp_password
SMTP_FROM=noreply@mail.kptom.com

# 服务器配置（生产环境建议 PORT=3002，与 Nginx 代理一致）
PORT=3002
NODE_ENV=production

# 前端配置（生产环境改为站点域名，如 http://47.91.108.104）
FRONTEND_URL=http://47.91.108.104
